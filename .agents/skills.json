{
  "version": 1,
  "source": "skills-list.md",
  "skillsRoot": ".agents/skills",
  "defaultChain": [
    "requirement-clarification",
    "doc-iteration",
    "spec-lock",
    "solution-options",
    "tech-plan-generator",
    "api-design",
    "shell-implementation",
    "tdd",
    "webapp-testing",
    "code-review",
    "documentation"
  ],
  "stageDefaults": {
    "initialized": [
      "requirement-clarification",
      "requirement-grilling",
      "setup-matt-pocock-skills"
    ],
    "requirements-draft": [
      "requirement-clarification",
      "doc-iteration",
      "spec-lock",
      "grill-me",
      "grill-with-docs",
      "to-prd"
    ],
    "requirements-confirmed": [
      "solution-options",
      "domain-modeling",
      "api-design"
    ],
    "solution-options": [
      "solution-options",
      "solution-stress-test",
      "triage"
    ],
    "solution-selected": [
      "tech-plan-generator",
      "api-design",
      "security-review",
      "to-issues",
      "triage"
    ],
    "implementation-ready": [
      "shell-implementation",
      "tdd",
      "webapp-testing",
      "code-review",
      "documentation",
      "diagnose",
      "improve-codebase-architecture",
      "git-guardrails-claude-code",
      "migrate-to-shoehorn",
      "scaffold-exercises",
      "setup-pre-commit"
    ]
  },
  "skills": [
    {
      "alias": "requirement-clarification",
      "skill": "ce-brainstorm",
      "level": "L1",
      "stage": "requirements",
      "description": "多轮澄清后产出结构化需求文档",
      "inputs": [
        "user request",
        "workflow-state.json",
        "SPECS/requirements/"
      ],
      "outputs": [
        "workflow/requirements.md"
      ]
    },
    {
      "alias": "requirement-grilling",
      "skill": "grilling",
      "level": "L1",
      "stage": "requirements",
      "description": "追问边界、异常、验收标准，把态度转成事实",
      "inputs": [
        "workflow/requirements.md",
        "user constraints"
      ],
      "outputs": [
        "open questions",
        "acceptance criteria"
      ]
    },
    {
      "alias": "doc-iteration",
      "skill": "doc-coauthoring",
      "level": "L1",
      "stage": "requirements",
      "description": "与用户协同修改 workflow/requirements.md",
      "inputs": [
        "workflow/requirements.md",
        "user feedback"
      ],
      "outputs": [
        "updated workflow/requirements.md"
      ]
    },
    {
      "alias": "spec-lock",
      "skill": "spec-driven-development",
      "level": "L1",
      "stage": "requirements",
      "description": "将需求转成可执行规格，先 spec 后代码",
      "inputs": [
        "workflow/requirements.md"
      ],
      "outputs": [
        "confirmed requirements",
        "implementation constraints"
      ]
    },
    {
      "alias": "domain-modeling",
      "skill": "domain-modeling",
      "level": "L1",
      "stage": "requirements",
      "description": "统一术语、实体、流程边界",
      "inputs": [
        "workflow/requirements.md",
        "SPECS/requirements/"
      ],
      "outputs": [
        "domain terms",
        "entity boundaries"
      ]
    },
    {
      "alias": "ubiquitous-language",
      "skill": "ubiquitous-language",
      "level": "L1",
      "stage": "requirements",
      "description": "统一领域术语表",
      "inputs": [
        "workflow/requirements.md",
        "domain terms"
      ],
      "outputs": [
        "ubiquitous language glossary"
      ]
    },
    {
      "alias": "solution-options",
      "skill": "design-an-interface",
      "level": "L1",
      "stage": "solution-options",
      "description": "产出 3 个技术方案和推荐理由",
      "inputs": [
        "workflow/requirements.md",
        "SPECS/API.md",
        "SPECS/DATABASE.md"
      ],
      "outputs": [
        "workflow/solution-options.md"
      ]
    },
    {
      "alias": "tech-plan-generator",
      "skill": "planning-and-task-breakdown",
      "level": "L1",
      "stage": "solution-selected",
      "description": "方案选定后拆实施计划",
      "inputs": [
        "workflow/solution-selected.md",
        "SPECS/API.md",
        "SPECS/DATABASE.md"
      ],
      "outputs": [
        "workflow/implementation-ready.md",
        "tasks/sprint-01.md"
      ]
    },
    {
      "alias": "api-design",
      "skill": "api-and-interface-design",
      "level": "L1",
      "stage": "solution-selected",
      "description": "前后端契约、模块边界、API 路由",
      "inputs": [
        "workflow/solution-selected.md",
        "SPECS/API.md",
        "frontend/SPECS/",
        "backend/SPECS/"
      ],
      "outputs": [
        "updated SPECS/API.md",
        "frontend/backend API boundary notes"
      ]
    },
    {
      "alias": "security-review",
      "skill": "security-and-hardening",
      "level": "L1",
      "stage": "implementation-ready",
      "description": "输入、鉴权、存储、外部调用",
      "inputs": [
        "workflow/implementation-ready.md",
        "SPECS/API.md",
        "backend/src/"
      ],
      "outputs": [
        "security findings",
        "hardening tasks"
      ]
    },
    {
      "alias": "shell-implementation",
      "skill": "implement",
      "level": "L1",
      "stage": "implementation-ready",
      "description": "按方案编码",
      "inputs": [
        "workflow/implementation-ready.md",
        "tasks/sprint-01.md",
        "frontend/SPECS/",
        "backend/SPECS/"
      ],
      "outputs": [
        "code changes",
        "verification evidence"
      ]
    },
    {
      "alias": "tdd",
      "skill": "tdd",
      "level": "L1",
      "stage": "implementation-ready",
      "description": "行为验收、单元和集成测试",
      "inputs": [
        "tasks/sprint-01.md",
        "acceptance criteria"
      ],
      "outputs": [
        "tests",
        "red-green-refactor evidence"
      ]
    },
    {
      "alias": "webapp-testing",
      "skill": "webapp-testing",
      "level": "L1",
      "stage": "implementation-ready",
      "description": "真实浏览器验证主业务闭环",
      "inputs": [
        "running app",
        "acceptance criteria"
      ],
      "outputs": [
        "browser smoke evidence",
        "screenshots or logs"
      ]
    },
    {
      "alias": "code-review",
      "skill": "code-review-and-quality",
      "level": "L1",
      "stage": "implementation-ready",
      "description": "实现后唯一 review gate",
      "inputs": [
        "code diff",
        "tests",
        "specs"
      ],
      "outputs": [
        "review findings",
        "merge risks"
      ]
    },
    {
      "alias": "documentation",
      "skill": "documentation-and-adrs",
      "level": "L1",
      "stage": "implementation-ready",
      "description": "记录 ADR、方案选择、技能追踪",
      "inputs": [
        "selected solution",
        "code changes",
        "verification evidence"
      ],
      "outputs": [
        "memory/decisions.md",
        "ADR or docs updates"
      ]
    },
    {
      "alias": "idea-exploration",
      "skill": "ce-ideate",
      "level": "L2",
      "trigger": "需求极模糊，需要先发散多个方向",
      "inputs": [
        "vague user request"
      ],
      "outputs": [
        "candidate directions",
        "tradeoff notes"
      ]
    },
    {
      "alias": "solution-stress-test",
      "skill": "grilling",
      "level": "L2",
      "trigger": "方案确定前需要压力测试",
      "inputs": [
        "workflow/solution-options.md"
      ],
      "outputs": [
        "risks",
        "challenge questions"
      ]
    },
    {
      "alias": "architecture-diagram",
      "skill": "architecture-diagram",
      "level": "L2",
      "trigger": "技术方案需要架构图、流程图或时序图",
      "inputs": [
        "architecture notes",
        "system boundaries"
      ],
      "outputs": [
        "architecture diagram artifact"
      ]
    },
    {
      "alias": "deep-module-design",
      "skill": "codebase-design",
      "level": "L2",
      "trigger": "需要强调深度模块设计时",
      "inputs": [
        "module responsibilities",
        "callers"
      ],
      "outputs": [
        "interface options",
        "module boundary recommendation"
      ]
    },
    {
      "alias": "prototype",
      "skill": "prototype",
      "level": "L2",
      "trigger": "技术方案不确定，先做可丢弃原型",
      "inputs": [
        "uncertain technical approach"
      ],
      "outputs": [
        "throwaway prototype",
        "learning notes"
      ]
    },
    {
      "alias": "debug",
      "skill": "ce-debug",
      "level": "L2",
      "trigger": "调试复杂问题，定位根因",
      "inputs": [
        "error output",
        "reproduction steps"
      ],
      "outputs": [
        "root cause",
        "fix plan"
      ]
    },
    {
      "alias": "debug-flow",
      "skill": "debugging-and-error-recovery",
      "level": "L2",
      "trigger": "构建、运行、测试失败时",
      "inputs": [
        "failed command",
        "logs",
        "reproduction steps"
      ],
      "outputs": [
        "debug trace",
        "recovery steps"
      ]
    },
    {
      "alias": "frontend-ui",
      "skill": "frontend-ui-engineering",
      "level": "L2",
      "trigger": "需要生成高质量后台 UI",
      "inputs": [
        "frontend/SPECS/",
        "design constraints"
      ],
      "outputs": [
        "UI implementation",
        "visual verification"
      ]
    },
    {
      "alias": "frontend-ui-design",
      "skill": "ce-frontend-design",
      "level": "L2",
      "trigger": "需要产出前端设计方案",
      "inputs": [
        "frontend requirements",
        "existing UI patterns"
      ],
      "outputs": [
        "UI design direction",
        "component plan"
      ]
    },
    {
      "alias": "ui-guidelines",
      "skill": "web-design-guidelines",
      "level": "L2",
      "trigger": "检查 UI 可用性、可访问性、一致性",
      "inputs": [
        "UI implementation",
        "screenshots"
      ],
      "outputs": [
        "UX/accessibility findings"
      ]
    },
    {
      "alias": "context-engineering",
      "skill": "context-engineering",
      "level": "L3",
      "description": "配置 AGENTS.md、SPEC、RULES、SKILLS 等项目控制文件",
      "inputs": [
        "AGENTS.md",
        "TEMPLATE.md",
        "rules/",
        ".agents/skills.json"
      ],
      "outputs": [
        "updated control files",
        "context routing notes"
      ]
    },
    {
      "alias": "agent-native-arch",
      "skill": "ce-agent-native-architecture",
      "level": "L3",
      "description": "设计阶段锁、workflow-state.json、硬停顿协议、Agent 可中断续跑机制",
      "inputs": [
        "workflow-state.json",
        "stage rules",
        "Agent workflow constraints"
      ],
      "outputs": [
        "workflow protocol",
        "hard-stop rules"
      ]
    },
    {
      "alias": "skill-routing",
      "skill": "using-agent-skills",
      "level": "L3",
      "description": "自动路由到正确技能",
      "inputs": [
        ".agents/skills.json",
        "user request",
        "workflow-state.json"
      ],
      "outputs": [
        "recommended skill aliases"
      ]
    },
    {
      "alias": "skill-craft",
      "skill": "skill-creator",
      "level": "L3",
      "description": "现成技能不够时定制新技能",
      "inputs": [
        "capability gap",
        "examples",
        "eval cases"
      ],
      "outputs": [
        "new or updated skill"
      ]
    },
    {
      "alias": "skill-optimize",
      "skill": "skill-optimizer",
      "level": "L3",
      "description": "优化现有技能",
      "inputs": [
        "existing skill",
        "failure cases",
        "eval results"
      ],
      "outputs": [
        "optimized skill",
        "eval plan"
      ]
    },
    {
      "alias": "grill-me",
      "skill": "grill-me",
      "level": "L1",
      "stage": "requirements",
      "description": "通用版逼问：把模糊需求变成共享理解",
      "inputs": [
        "user request",
        "workflow-state.json"
      ],
      "outputs": [
        "problem statement",
        "shared understanding"
      ]
    },
    {
      "alias": "grill-with-docs",
      "skill": "grill-with-docs",
      "level": "L1",
      "stage": "requirements",
      "description": "工程版逼问：对照代码库发现矛盾，并产出 ADR 和 glossary",
      "inputs": [
        "user request",
        "codebase",
        "workflow-state.json"
      ],
      "outputs": [
        "problem statement",
        "ADR and glossary drafts"
      ]
    },
    {
      "alias": "diagnose",
      "skill": "diagnosing-bugs",
      "level": "L2",
      "stage": "implementation-ready",
      "description": "复现→最小化→假设→修：硬 bug 和性能回归的诊断循环",
      "inputs": [
        "error output",
        "reproduction steps",
        "codebase"
      ],
      "outputs": [
        "root cause",
        "fix plan"
      ]
    },
    {
      "alias": "to-prd",
      "skill": "to-prd",
      "level": "L1",
      "stage": "requirements",
      "description": "从对话到 PRD：不追问，只合成已讨论内容",
      "inputs": [
        "conversation context",
        "codebase understanding"
      ],
      "outputs": [
        "PRD document",
        "issue tracker entry"
      ]
    },
    {
      "alias": "to-issues",
      "skill": "to-issues",
      "level": "L1",
      "stage": "solution-selected",
      "description": "PRD → 工单：用 tracer-bullet 垂直切片拆成可并行任务",
      "inputs": [
        "workflow/solution-selected.md",
        "PRD"
      ],
      "outputs": [
        "issue tracker issues",
        "dependency DAG"
      ]
    },
    {
      "alias": "triage",
      "skill": "triage",
      "level": "L1",
      "stage": "solution-selected",
      "description": "优先级分类：把 issue 和外部 PR 推过 triage 状态机",
      "inputs": [
        "issue tracker items"
      ],
      "outputs": [
        "categorised issues",
        "agent-ready briefs"
      ]
    },
    {
      "alias": "improve-codebase-architecture",
      "skill": "improve-codebase-architecture",
      "level": "L2",
      "stage": "implementation-ready",
      "description": "周期性救火：扫描代码库，以 HTML 报告展示深化机会并推进",
      "inputs": [
        "codebase"
      ],
      "outputs": [
        "HTML report",
        "refactor plan"
      ]
    },
    {
      "alias": "setup-matt-pocock-skills",
      "skill": "setup-matt-pocock-skills",
      "level": "L3",
      "stage": "initialized",
      "description": "一键安装工程技能集：配置 issue tracker、triage 标签和领域文档布局",
      "inputs": [
        "repo root"
      ],
      "outputs": [
        "issue tracker config",
        "triage labels",
        "domain doc layout"
      ]
    },
    {
      "alias": "git-guardrails-claude-code",
      "skill": "git-guardrails-claude-code",
      "level": "L2",
      "stage": "implementation-ready",
      "description": "设置 Claude Code 的 git 安全护栏，拦截危险 git 命令",
      "inputs": [
        "repo root"
      ],
      "outputs": [
        "git guardrails hooks"
      ]
    },
    {
      "alias": "migrate-to-shoehorn",
      "skill": "migrate-to-shoehorn",
      "level": "L2",
      "stage": "implementation-ready",
      "description": "把测试文件中的 `as` 类型断言迁移到 @total-typescript/shoehorn",
      "inputs": [
        "test files"
      ],
      "outputs": [
        "migrated tests"
      ]
    },
    {
      "alias": "scaffold-exercises",
      "skill": "scaffold-exercises",
      "level": "L2",
      "stage": "implementation-ready",
      "description": "创建带章节、题目、解答和讲解的练习目录结构",
      "inputs": [
        "course outline"
      ],
      "outputs": [
        "exercise directory structure"
      ]
    },
    {
      "alias": "setup-pre-commit",
      "skill": "setup-pre-commit",
      "level": "L2",
      "stage": "implementation-ready",
      "description": "配置 Husky + lint-staged 的 pre-commit hooks（格式化、类型检查、测试）",
      "inputs": [
        "repo root"
      ],
      "outputs": [
        "pre-commit hooks"
      ]
    },
    {
      "alias": "handoff",
      "skill": "handoff",
      "level": "L3",
      "description": "阶段间切换 Agent/LLM 的交接协议",
      "inputs": [
        "current task state",
        "diff",
        "verification results"
      ],
      "outputs": [
        "handoff document"
      ]
    }
  ]
}
